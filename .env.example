# ===== SUPABASE =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===== APP =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EPK Supreme

# ===== MODEL RUNTIME =====
MODEL_PROVIDER=deepseek
ARTISTEPKS_MODEL_TIMEOUT_MS=120000
ARTISTEPKS_MODEL_RETRIES=1

# ===== DEEPSEEK =====
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== OLLAMA (Local - Optional) =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5

# ===== EMBEDDED AGENT SERVER =====
ARTISTEPKS_AGENT_PROVIDER=local
ARTISTEPKS_DEPLOYMENT_TARGET=this-server
ARTISTEPKS_DEFAULT_MODEL=deepseek-chat
ARTISTEPKS_ENABLE_RESEARCH=false
ARTISTEPKS_FALLBACK_TO_LOCAL=true

# ===== OPENCLAW (Optional) =====
OPENCLAW_BASE_URL=
OPENCLAW_AGENT_ENDPOINT=/api/v1/artistepks/launch-kit
OPENCLAW_API_KEY=
OPENCLAW_TIMEOUT_MS=30000

# ===== RESEARCH CONNECTORS (Optional) =====
SERPER_API_KEY=
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===== MEDIA GENERATION (Optional) =====
REMOTION_ENABLED=false
